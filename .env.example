# GitHub App credentials (from GitHub App settings page)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Classic OAuth App credentials (for starring — requires public_repo scope)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Base URL for redirects (e.g., https://ethstar.org or http://localhost:5173)
BASE_URL=http://localhost:5173

# Vercel KV (auto-injected when KV store is linked in Vercel dashboard)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Comma-separated allowlist for OAuth redirect host validation (defense-in-depth)
ALLOWED_HOSTS=localhost
